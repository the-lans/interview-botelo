# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Redis
REDIS_URL=redis://:PASSWORD@HOST:6379

# Auth
JWT_SECRET=change_me
SESSION_SECRET=change_me

# SMTP
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=claw@botelo.ru
SMTP_PASS=change_me
SMTP_FROM=claw@botelo.ru

# LLM
LLM_PROVIDER=__TBD__
LLM_API_KEY=__TBD__

# OpenAI OAuth (for local OpenClaw deployments only)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_OAUTH_ACCESS=
OPENAI_OAUTH_REFRESH=
